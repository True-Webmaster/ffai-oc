# ── KeyMux Configuration ─────────────────────────────────────────────────────

# ── Keys ──────────────────────────────────────────────────────────────────────

# Name of the environment variable that holds your comma-separated API keys.
# KeyMux never stores keys directly — it reads them from whatever env var you point to.
# Examples: GEMINI_API_KEYS, OPENAI_KEYS, MY_API_KEYS  (default: API_KEYS)
KEYS_VAR=API_KEYS

# ── Upstream ──────────────────────────────────────────────────────────────────

# URL of the upstream API (required in proxy mode, optional in rotation mode)
# Examples:
#   OpenAI:     https://api.openai.com/v1
#   Gemini:     https://generativelanguage.googleapis.com/v1beta/openai
#   Anthropic:  https://api.anthropic.com
#   Local:      http://localhost:11434/v1
UPSTREAM_URL=

# Port to listen on (default: 8002)
PORT=8002

# Bind address (default: 0.0.0.0 — use 127.0.0.1 to restrict to localhost)
BIND_ADDRESS=0.0.0.0

# ── Mode ──────────────────────────────────────────────────────────────────────

# "proxy"    — full gateway: forwards requests to upstream with key injection (default)
# "rotation" — key-rotation only: no proxy, just exposes /key endpoint for clients
#              to fetch the next available key
MODE=proxy

# ── Auth Scheme (outbound — how keys are sent to upstream) ────────────────────

# How keys are injected into upstream requests:
#   "bearer"  — Authorization: Bearer <key>  (default, works with OpenAI, Gemini, etc.)
#   "header"  — Custom header, set AUTH_HEADER to the header name (e.g. x-api-key)
#   "query"   — Query parameter, set AUTH_QUERY to the param name (e.g. ?key=<key>)
#   "none"    — No auth injection (keys still rotated, useful for rate-limit-only scenarios)
AUTH_SCHEME=bearer

# Custom header name when AUTH_SCHEME=header (default: authorization)
AUTH_HEADER=authorization

# Query parameter name when AUTH_SCHEME=query (default: key)
AUTH_QUERY=key

# ── Inbound Auth (protect KeyMux endpoints) ───────────────────────────────────

# Shared secret for proxy and rotation endpoints. Clients must send:
#   Authorization: Bearer <PROXY_KEY>
# Leave empty to disable inbound auth (not recommended for public-facing deployments).
PROXY_KEY=

# Shared secret for admin endpoints (/stats). Falls back to PROXY_KEY if not set.
# Leave empty to make /stats open (or protected by PROXY_KEY only).
ADMIN_KEY=

# ── Path Restriction ─────────────────────────────────────────────────────────

# Comma-separated allowed path prefixes. Empty = allow all paths.
# Examples: "/v1/", "/api/", "/v1/,/v2/"
ALLOWED_PATHS=

# ── Retry & Cooldown ─────────────────────────────────────────────────────────

# Max retry attempts per request (default: 3, capped at key count)
MAX_RETRIES=3

# Default cooldown in seconds when upstream returns 429 without Retry-After (default: 60)
DEFAULT_COOLDOWN=60

# Maximum cooldown in seconds (caps Retry-After to prevent abuse) (default: 300)
MAX_COOLDOWN=300

# Comma-separated HTTP status codes that trigger retry with next key (default: 429,502,503)
RETRYABLE_STATUSES=429,502,503

# ── Circuit Breaker (kill switch) ─────────────────────────────────────────────

# Number of consecutive errors that trips the circuit breaker. 0 = disabled. (default: 0)
CB_THRESHOLD=0

# Time window in ms to count errors (default: 60000 = 1 minute)
CB_WINDOW=60000

# How long to block all requests when circuit is open, in ms (default: 120000 = 2 minutes)
CB_COOLDOWN=120000

# ── Request Limits ────────────────────────────────────────────────────────────

# Maximum request body size in bytes (default: 2097152 = 2MB)
MAX_BODY_SIZE=2097152

# Request timeout to upstream in ms (default: 120000 = 2 minutes)
REQUEST_TIMEOUT=120000

# ── Alerts ────────────────────────────────────────────────────────────────────

# Webhook URL for alerts (all-keys-exhausted, circuit-breaker events). Leave empty to disable.
ALERT_WEBHOOK_URL=

# Webhook request timeout in ms (default: 5000)
ALERT_TIMEOUT=5000

# ── Stats ─────────────────────────────────────────────────────────────────────

# Stats file path (default: ./data/stats.json)
STATS_FILE=./data/stats.json

# Stats flush interval in ms (default: 60000 = 1 minute)
STATS_FLUSH_INTERVAL=60000

# Days of stats history to retain (default: 7)
STATS_RETENTION_DAYS=7

# ── Shutdown ──────────────────────────────────────────────────────────────────

# Force-exit timeout after graceful shutdown in ms (default: 5000)
SHUTDOWN_TIMEOUT=5000
