# ── FFAI — Free Freaking AI ──────────────────────────────────────────────────
# Copy to .env and fill in your values. Provider config lives in config.json.

# ── Server ───────────────────────────────────────────────────────────────────

# Port to listen on (default: 8010)
FFAI_PORT=8010

# Bind address (default: 127.0.0.1 — set to 0.0.0.0 only if you know what you're doing)
FFAI_BIND=127.0.0.1

# ── Auth ─────────────────────────────────────────────────────────────────────

# Shared secret that clients must send as: Authorization: Bearer <FFAI_KEY>
# REQUIRED when FFAI_BIND is not loopback.
FFAI_KEY=

# Admin endpoints (/stats, /savings, /providers, /smush, detailed /health).
# Falls back to FFAI_KEY if unset.
FFAI_ADMIN_KEY=

# ── Provider API Keys ────────────────────────────────────────────────────────
# Each provider in config.json references one of these via "keys_var".
# Values are comma-separated lists of upstream API keys.

GEMINI_API_KEYS=
GROQ_API_KEYS=
CEREBRAS_API_KEYS=
# OLLAMA runs locally and needs no key

# ── Config & Stats Paths ─────────────────────────────────────────────────────

# Provider config file (default: ./config.json)
FFAI_CONFIG=./config.json

# Stats persistence file (default: ./data/stats.json)
FFAI_STATS_FILE=./data/stats.json

# Days of daily stats to retain (default: 7)
FFAI_STATS_RETENTION_DAYS=7

# Stats flush interval in ms (default: 60000)
FFAI_STATS_FLUSH_INTERVAL=60000

# ── Timeouts ─────────────────────────────────────────────────────────────────

# Upstream request timeout in ms (default: 120000)
FFAI_REQUEST_TIMEOUT=120000

# SSE streaming timeout in ms (0 = auto: 3x REQUEST_TIMEOUT, min 360s)
FFAI_SSE_TIMEOUT=0

# Max request body size in bytes (default: 2MB)
FFAI_MAX_BODY_SIZE=2097152

# Key-acquire wait before returning 503 (default: 3000ms)
FFAI_ACQUIRE_WAIT_MS=3000

# Graceful shutdown drain timeout (default: 10000ms)
FFAI_DRAIN_TIMEOUT=10000

# ── Model Discovery ──────────────────────────────────────────────────────────

# Discovery request timeouts (ms)
FFAI_DISCOVERY_TIMEOUT=30000
FFAI_DISCOVERY_SOCKET_TIMEOUT=15000
FFAI_DISCOVERY_SPEC_TIMEOUT=30000

# Minimum model specs for inclusion in /models
FFAI_MIN_CONTEXT_WINDOW=32768
FFAI_MIN_OUTPUT_TOKENS=4096
FFAI_MIN_PARAM_BILLIONS=4

# /models response cache TTL (default: 5 min)
FFAI_MODELS_CACHE_TTL=300000

# Max models tracked in capability store LRU (default: 2000)
FFAI_MAX_CAPABILITY_MODELS=2000

# Validate keys against upstream /models on startup (default: false)
FFAI_VALIDATE_KEYS=false
FFAI_VALIDATE_TIMEOUT=10000

# ── Brute-force Protection ───────────────────────────────────────────────────

# Max auth failures per window before an IP is blocked (default: 10)
FFAI_AUTH_FAIL_MAX=10

# Failure window in ms (default: 60000)
FFAI_AUTH_FAIL_WINDOW=60000

# Block duration in ms after too many failures (default: 300000 = 5 min)
FFAI_AUTH_BLOCK_DURATION=300000

# ── Alerts ───────────────────────────────────────────────────────────────────

# Webhook URL for circuit-breaker / all-keys-exhausted events. Leave empty to disable.
FFAI_ALERT_WEBHOOK=

# Webhook request timeout (default: 5000ms)
FFAI_ALERT_TIMEOUT=5000

# ── Logging ──────────────────────────────────────────────────────────────────

# Emit structured JSON logs instead of human-readable lines
FFAI_STRUCTURED_LOGS=false

# ── OpenClaw Integration (optional) ──────────────────────────────────────────

# Sync discovered models to OpenClaw's model picker
FFAI_OPENCLAW_SYNC=false
# FFAI_OPENCLAW_JSON=$HOME/.openclaw/openclaw.json

# Also write per-agent model overrides
FFAI_OPENCLAW_SYNC_AGENTS=false
# FFAI_OPENCLAW_AGENTS_DIR=$HOME/.openclaw/agents
