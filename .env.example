# ── KeyMux Configuration ─────────────────────────────────────────────────────
# Multi-provider config is in providers.json (see providers.json.example)

# ── Server ───────────────────────────────────────────────────────────────────

# Port to listen on (default: 8002)
PORT=8002

# Bind address (default: 0.0.0.0 — use 127.0.0.1 to restrict to localhost)
BIND_ADDRESS=0.0.0.0

# ── Providers ────────────────────────────────────────────────────────────────

# Path to providers config file (default: ./providers.json)
PROVIDERS_FILE=./providers.json

# ── API Keys (referenced by providers.json via keys_var) ─────────────────────
# Each provider in providers.json points to an env var that holds comma-separated keys.
# Example: if providers.json has "keys_var": "GEMINI_API_KEYS", define it here:
#
# GEMINI_API_KEYS=key1,key2,key3
# GROQ_API_KEYS=gsk_abc,gsk_def
# ANTHROPIC_KEYS=sk-ant-xxx,sk-ant-yyy

# ── Inbound Auth (protect KeyMux endpoints) ───────────────────────────────────

# Shared secret for proxy and rotation endpoints. Clients must send:
#   Authorization: Bearer <PROXY_KEY>
# Leave empty to disable inbound auth (not recommended for public-facing deployments).
PROXY_KEY=

# Shared secret for admin endpoints (/stats, /health detail view).
# If not set, falls back to PROXY_KEY. If neither is set, admin endpoints are open.
ADMIN_KEY=

# ── Alerts ────────────────────────────────────────────────────────────────────

# Webhook URL for alerts (all-keys-exhausted, circuit-breaker events). Leave empty to disable.
ALERT_WEBHOOK_URL=

# Webhook request timeout in ms (default: 5000)
ALERT_TIMEOUT=5000

# ── Stats ─────────────────────────────────────────────────────────────────────

# Stats file path (default: ./data/stats.json)
STATS_FILE=./data/stats.json

# Stats flush interval in ms (default: 60000 = 1 minute)
STATS_FLUSH_INTERVAL=60000

# Days of stats history to retain (default: 7)
STATS_RETENTION_DAYS=7

# ── Shutdown ──────────────────────────────────────────────────────────────────

# Force-exit timeout after graceful shutdown in ms (default: 5000)
SHUTDOWN_TIMEOUT=5000
