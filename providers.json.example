{
  "gemini": {
    "mode": "proxy",
    "upstream_url": "https://generativelanguage.googleapis.com/v1beta/openai",
    "keys_var": "GEMINI_API_KEYS",
    "auth_scheme": "bearer"
  },
  "groq": {
    "mode": "proxy",
    "upstream_url": "https://api.groq.com/openai",
    "keys_var": "GROQ_API_KEYS",
    "auth_scheme": "bearer"
  },
  "anthropic": {
    "mode": "proxy",
    "upstream_url": "https://api.anthropic.com",
    "keys_var": "ANTHROPIC_KEYS",
    "auth_scheme": "header",
    "auth_header": "x-api-key"
  },
  "local": {
    "mode": "proxy",
    "upstream_url": "http://localhost:11434/v1",
    "keys_var": "LOCAL_KEYS",
    "auth_scheme": "none"
  },
  "spare-keys": {
    "mode": "rotation",
    "keys_var": "SPARE_API_KEYS"
  }
}
